DATABASE_URL="postgresql://nasiha:nasiha@localhost:5432/nasiha?schema=public"
REDIS_URL="redis://localhost:6379"

# Clerk (https://dashboard.clerk.com) — see web/README.md for full setup steps,
# including the required "Restricted sign-up mode" dashboard step.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."
CLERK_WEBHOOK_SIGNING_SECRET="whsec_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/accept-invite"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/whats-new"
NEXT_PUBLIC_CLERK_AFTER_SIGN_OUT_URL="/"
# Used to build the redirectUrl passed to Clerk's invitation API (lib/clerk-admin.ts).
# Use http://localhost:3010 for docker-compose (app container's 3000 is published as
# 3010 on the host), or your public domain in production (e.g. https://nasihaforyou.org).
NEXT_PUBLIC_APP_URL="http://localhost:3010"

# Resend (https://resend.com) — sends the /join application confirmation email.
# Left unset in dev: lib/email.ts logs and skips sending rather than failing.
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="Nasiha <no-reply@mail.nasihaforyou.org>"

# MinIO (object storage — Our Team photos, PRD §4.12/§9). Matches the
# docker-compose "minio" service; point at a real MinIO/S3-compatible
# endpoint in production.
MINIO_ENDPOINT="localhost"
MINIO_PORT="9000"
MINIO_USE_SSL="false"
MINIO_ACCESS_KEY="nasiha"
MINIO_SECRET_KEY="nasiha123"
MINIO_BUCKET_AVATARS="avatars"

# Stripe (https://dashboard.stripe.com/test/apikeys) — /donate checkout (§4.14).
# STRIPE_WEBHOOK_SIGNING_SECRET comes from the webhook endpoint you register
# pointing at <your-app-url>/api/webhooks/stripe (or `stripe listen` locally).
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SIGNING_SECRET="whsec_..."

# Meilisearch (search, §7.2/§8) — matches the docker-compose "meilisearch"
# service. Directory search (and later Blog/Library/Forums search) is
# powered by this. Profile writes sync to it via the BullMQ worker
# (`npm run worker`), not inline in the request path.
MEILI_HOST="http://localhost:7700"
MEILI_MASTER_KEY="nasiha-dev-master-key"

