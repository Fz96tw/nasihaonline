// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  guest
  applicant
  member
  moderator
  admin
}

// Member-facing classification, distinct from the system Role — PRD §2.2/§7.1
// calls this out as a required first-class field on User, separate from role.
enum Tier {
  active
  associate
  student
  friend
}

model User {
  id          String     @id @default(cuid())
  clerkUserId String     @unique
  email       String     @unique
  name        String?
  role        Role       @default(applicant)
  tier        Tier?
  // Trust & Safety state (§4.15) — deliberately separate from role/tier: a
  // suspended member is blocked from login/member routes (enforced in app
  // code, not here) but their historical ledger/content rows are untouched.
  suspended   Boolean    @default(false)
  suspendedAt DateTime?
  profile     Profile?
  // Denormalized donation attribution only (§4.14) — never joined against
  // for Knowledge Hours/tier logic. See Donation model for the guarantee.
  donations   Donation[]

  // Knowledge Hours ledger (§4.4) — every relation named since a single
  // user can be the balance-holder, the actor/counterpart on the
  // originating ContributionEvent, or an admin who created/resolved a
  // ledger row, all independently of each other.
  contributionLedgerEntries       ContributionLedger[] @relation("LedgerUser")
  contributionAdjustmentsCreated  ContributionLedger[] @relation("LedgerCreatedBy")
  contributionResolutions         ContributionLedger[] @relation("LedgerResolvedBy")
  contributionEventsAsActor       ContributionEvent[]  @relation("ContributionEventActor")
  contributionEventsAsCounterpart ContributionEvent[]  @relation("ContributionEventCounterpart")

  // Inbox (§4.7) — directory-originated, two-party only, no live chat.
  sentInboxMessages       InboxMessage[]   @relation("InboxMessageSender")
  receivedInboxMessages   InboxMessage[]   @relation("InboxMessageRecipient")
  sentMeetingRequests     MeetingRequest[] @relation("MeetingRequestSender")
  receivedMeetingRequests MeetingRequest[] @relation("MeetingRequestRecipient")

  notifications Notification[]

  // Events (§4.6) — hostId is required and un-cascaded on delete, same
  // convention as ContributionEvent.actorId, since a host's past events
  // are historical record even if their account is later removed.
  hostedEvents     Event[]      @relation("EventHost")
  eventRsvps       RSVP[]       @relation("EventRsvp")
  eventAttendances Attendance[] @relation("EventAttendance")

  // Blog / Knowledge Library / Forums (§4.8/§4.9/§4.13).
  postsAuthored             Post[]          @relation("PostAuthor")
  postComments              PostComment[]   @relation("PostCommentAuthor")
  knowledgeItemsContributed KnowledgeItem[] @relation("KnowledgeContributor")
  forumThreads              ForumThread[]   @relation("ForumThreadAuthor")
  forumPosts                ForumPost[]     @relation("ForumPostAuthor")
  forumFollows              ForumFollow[]

  // Trust & Safety / Compliance / Notifications (§4.10/§4.15) — a member can
  // appear on either side of a conduct report (reported or reporting) and
  // only admins handle reports/requests, so each role gets its own named
  // relation, same multi-role convention as ContributionLedger's User
  // relations above.
  conductViolationsReported  CodeOfConductViolation[] @relation("ConductViolationReported")
  conductViolationsFiled     CodeOfConductViolation[] @relation("ConductViolationReporter")
  conductViolationsHandled   CodeOfConductViolation[] @relation("ConductViolationHandledBy")
  privacyDataRequests        PrivacyDataRequest[]     @relation("PrivacyRequestUser")
  privacyDataRequestsHandled PrivacyDataRequest[]     @relation("PrivacyRequestHandledBy")
  notificationPreferences    NotificationPreference[]
  announcementsAuthored      Announcement[]           @relation("AnnouncementAuthor")
  announcementsRetracted     Announcement[]           @relation("AnnouncementRetractedBy")
  surveysAuthored            Survey[]                 @relation("SurveyAuthor")
  surveysClosed              Survey[]                 @relation("SurveyClosedBy")
  surveyInvitations          SurveyInvitation[]

  // Tier-promotion audit trail (§7.3) — a user accrues entries as the
  // subject of a change and, separately, as the admin who made one.
  tierHistoryEntries TierHistory[] @relation("TierHistorySubject")
  tierChangesMade    TierHistory[] @relation("TierHistoryActor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

// Append-only audit trail for admin-driven tier changes (§7.3, §11) —
// written whenever an admin edit actually changes User.tier, independent
// of the once-only tier assignment made at application approval.
model TierHistory {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("TierHistorySubject", fields: [userId], references: [id])

  fromTier Tier?
  toTier   Tier?

  changedByUserId String
  changedByUser   User   @relation("TierHistoryActor", fields: [changedByUserId], references: [id])

  reason String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("tier_history")
}

// Minimal seed row created alongside every new User (lib/clerk-sync.ts) so
// the full Profile domain (PRD §4.3 — avatar upload, directory prefs, skills)
// has a real record to extend rather than needing a backfill later.
model Profile {
  id                    String         @id @default(cuid())
  userId                String         @unique
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                   String?
  // MinIO object key (not a servable URL — see getProfileAvatarUrl in lib/storage.ts),
  // same convention as TeamMember.photoUrl.
  avatarUrl             String?
  countryRegion         String?
  titleSpecialty        String?
  careerStage           String?
  // Free-text fallback only, for expertise entries that don't map to a
  // seeded Skill tag (PRD §4.3/§7.3) — tagged expertise lives in
  // ProfileSkill. Not the source of truth for Directory tag filtering.
  expertiseAreas        String[]       @default([])
  learningTopics        String?
  interestAreas         InterestArea[] @default([])
  // How the member can participate (§3.1) — collected at application time
  // only until now; also editable here since availability changes over time.
  availability          ApplicationAvailability[] @default([])
  skills                ProfileSkill[]
  // Directory visibility prefs (§4.3/§4.5/§9) — enforced server-side in
  // lib/members-server.ts, not just hidden client-side.
  listInDirectory       Boolean        @default(true)
  showSpecialtyLocation Boolean        @default(true)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@map("profiles")
}

// Normalized expertise tag (PRD §4.3/§7.3 — migrates "areas of expertise"
// from pure free text toward a taggable model to power Directory
// search/filter). Seeded from a fixed list (prisma/seed.ts); members can
// only attach existing skills, not create new ones inline — anything not
// in the seed list stays in Profile.expertiseAreas as free-text fallback.
model Skill {
  id        String         @id @default(cuid())
  name      String         @unique
  slug      String         @unique
  createdAt DateTime       @default(now())
  profiles  ProfileSkill[]

  @@map("skills")
}

model ProfileSkill {
  profileId String
  profile   Profile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  skillId   String
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([profileId, skillId])
  @@index([skillId])
  @@map("profile_skills")
}

// Rollout phase for public applications (PRD §3.2). Gates whether the
// application form's professional-reference field is required.
enum AdmissionPhase {
  founding_cohort
  referral_driven_growth
  open_applications
}

// Singleton row (fixed id = 1) holding site-wide, admin-editable settings.
// Extend with more columns as future settings (e.g. inactivity threshold,
// §3.4) are added, rather than introducing a generic key/value table.
model SiteSettings {
  id             Int            @id @default(1)
  admissionPhase AdmissionPhase @default(referral_driven_growth)
  updatedAt      DateTime       @updatedAt

  @@map("site_settings")
}

enum CareerStage {
  expert
  early_career
  student
}

enum ApplicationAvailability {
  virtual_meeting
  in_person
  online_review
}

// Fixed, admin-curated interest tags shown as a multi-select on both the
// join application and the profile edit page. Supersedes the old, narrower
// AreaOfInterest categorization (healthcare/science/law/business/it),
// removed in favor of this single list.
enum InterestArea {
  arts_crafts
  basic_science_research
  biotechnology
  business
  clinical_research
  culinary_arts
  data_analytics
  e_learning
  education
  finance_investing
  health_wellness
  health_tech
  healthcare
  leadership_management
  literature_writing
  marketing_sales
  science_philosophy
  sustainability_environment
  tech_development
  travel_culture
}

enum ApplicationStatus {
  submitted
  under_review
  approved
  rejected
}

// Public membership application (PRD §3.1). professionalReference* is
// collected unconditionally but only *required* once admissionPhase =
// open_applications — enforced in application code (lib/validation), not
// the DB, since the requirement changes at runtime via SiteSettings.
enum TeamRoleBadge {
  founder
  board_member
  partner
}

// Public "Our Team" page content (PRD §4.12), admin-managed. photoUrl stores
// the MinIO object key (not a browser-facing URL) — signed URLs are
// generated per-request since they expire, same rationale as Profile
// avatars once those exist (§4.3).
model TeamMember {
  id           String        @id @default(cuid())
  name         String
  roleBadge    TeamRoleBadge
  title        String
  bio          String
  photoUrl     String?
  displayOrder Int           @default(0)
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("team_members")
}

enum DonationFrequency {
  one_time
  recurring
}

// Individual donation record (PRD §4.14). Deliberately has NO relation to
// ContributionLedger or User.tier anywhere in this model or in any code
// path — donations must never confer Knowledge Hours or membership
// advantage. userId is purely a denormalized "who donated" attribution
// (nullable — most donors won't be logged in) and is never read by any
// tier/ledger logic. Rows are created only from the Stripe webhook on
// confirmed payment (app/api/webhooks/stripe/route.ts), never at checkout
// creation time, so a failed/cancelled/expired session never produces one.
model Donation {
  id                      String            @id @default(cuid())
  donorName               String
  donorEmail              String
  userId                  String?
  user                    User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  amountCents             Int
  currency                String            @default("usd")
  frequency               DonationFrequency
  recognitionConsent      Boolean           @default(false)
  emailUpdatesOptIn       Boolean           @default(false)
  note                    String?
  stripeCheckoutSessionId String            @unique
  stripeSubscriptionId    String?
  createdAt               DateTime          @default(now())

  @@map("donations")
}

// A public /contact form submission (PRD §5 IA). Persisted as a durable
// record so a submission survives even if the notification email below
// fails or RESEND_API_KEY isn't configured — the email is the fast path,
// this row is the fallback so nothing is silently lost.
model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model MembershipApplication {
  id                           String                    @id @default(cuid())
  firstName                    String
  lastName                     String
  email                        String
  professionalTitle            String
  // Nullable only because donation-triggered auto-applications (see
  // sourcedFromDonation below) don't collect it — a manually-submitted
  // application always has this required by applicationSchema's Zod
  // validation regardless of DB nullability.
  careerStage                  CareerStage?
  availability                 ApplicationAvailability[]
  interestAreas                InterestArea[]
  countryRegion                String
  referral                     String?
  whyJoin                      String
  expertiseToShare             String
  topicsToLearn                String
  professionalReferenceName    String?
  professionalReferenceContact String?
  codeOfConductAcceptedAt      DateTime
  emailUpdatesOptIn            Boolean                   @default(false)
  status                       ApplicationStatus         @default(submitted)

  // True when this application was auto-submitted from the donate form's
  // "also apply as a Friend" checkbox (PRD §4.14) rather than filled out
  // directly on /join — still goes through the same admin review queue,
  // just pre-fills only the fields a donation checkout actually has
  // (name/email), leaving career/interest fields blank for the admin to
  // see as unanswered rather than fabricated.
  sourcedFromDonation Boolean @default(false)

  // Applicant's own tier preference (e.g. "just want Friend of Nasiha access")
  // — a non-binding hint only. It pre-fills the admin's assignedTier selector
  // at review time but the admin can freely override it; assignedTier below
  // remains the sole source of truth for what tier is actually granted.
  requestedTier Tier?

  // Review outcome (PRD §3.3/§4.11). Set once by the admin review action;
  // the application row itself is the audit trail — never deleted, so these
  // stay populated permanently once a decision is made. reviewedByEmail is
  // a denormalized snapshot (not a live FK) since this is a log entry, not
  // a relation that needs to track the reviewer's current identity.
  assignedTier                Tier?
  adminNote                   String?
  adminNoteVisibleToApplicant Boolean   @default(false)
  reviewedAt                  DateTime?
  reviewedByEmail             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("membership_applications")
}

// Phase 3 data model — Knowledge Hours ledger + Inbox (PRD §4.4/§4.7).
// ContributionRule and ContributionEvent are kept separate from
// ContributionLedger per §4.4/§7: Rule is the configurable rate card,
// Event is the descriptive "what happened" record (who/what/when),
// Ledger is the append-only set of balance-affecting rows. A balance is
// always SUM(ledger.hours WHERE status = confirmed) — never a stored,
// directly-mutated field.
enum LedgerTransactionType {
  earned
  spent
  // No `transferred` — the Charter explicitly prohibits moving Knowledge
  // Hours from one member's balance to another's (§4.4). `adjusted` is
  // the only way a balance changes outside normal earn/spend, and it
  // requires an admin actor + reason (enforced in app code, not the DB).
  adjusted
}

enum LedgerStatus {
  pending
  confirmed
  rejected
}

// Where a ContributionEvent originated (§4.4's hybrid auto/self-report
// model). `event_attendance` rows also carry a real FK via
// ContributionEvent.attendanceId (added once the auto-earn trigger was
// wired up), so this tag is redundant with that link for those rows but
// stays as the uniform discriminator across all sources.
enum ContributionSource {
  event_attendance
  meeting_request
  self_reported
  blog_post
}

// Configurable earn/spend rate card (§4.4) — not hardcoded, so rates can
// be tuned by the org over time. `hours` is the unsigned magnitude;
// ContributionLedger applies the sign based on `type` when a transaction
// is posted.
model ContributionRule {
  id          String                @id @default(cuid())
  activityKey String                @unique
  label       String
  type        LedgerTransactionType
  hours       Decimal               @db.Decimal(5, 2)
  active      Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  events ContributionEvent[]

  @@map("contribution_rules")
}

// The activity occurrence a ledger row is derived from (§4.4): who did
// it, who the counterpart was (if any — peer confirmation target), and
// where it came from. Kept separate from ContributionLedger so a single
// occurrence's descriptive detail isn't duplicated across rows, and so
// admin `adjusted` corrections (which have no originating activity) can
// leave `ContributionLedger.eventId` null.
model ContributionEvent {
  id            String             @id @default(cuid())
  ruleId        String
  rule          ContributionRule   @relation(fields: [ruleId], references: [id])
  actorId       String
  actor         User               @relation("ContributionEventActor", fields: [actorId], references: [id])
  counterpartId String?
  counterpart   User?              @relation("ContributionEventCounterpart", fields: [counterpartId], references: [id])
  note          String?
  source        ContributionSource
  occurredAt    DateTime           @default(now())
  createdAt     DateTime           @default(now())

  // Set only for source = event_attendance: the host's Attendance row that
  // triggered this auto-earn (§4.4/§4.6). The audit-trail link back to the
  // originating Event/Attendance record, one-to-one since a given Attendance
  // row can only ever produce a single earn transaction.
  attendanceId String?     @unique
  attendance   Attendance? @relation(fields: [attendanceId], references: [id])

  ledgerEntries ContributionLedger[]

  @@index([actorId])
  @@index([counterpartId])
  @@map("contribution_events")
}

// The immutable, append-only balance-affecting transaction (§4.4). Never
// updated in place after resolution — status moves pending -> confirmed
// | rejected exactly once. `hours` is signed (positive for earned,
// negative for spent, either sign for an admin `adjusted` correction) so
// a plain SUM() over confirmed rows yields the balance.
model ContributionLedger {
  id     String @id @default(cuid())
  userId String
  user   User   @relation("LedgerUser", fields: [userId], references: [id])

  eventId String?
  event   ContributionEvent? @relation(fields: [eventId], references: [id])

  type   LedgerTransactionType
  status LedgerStatus          @default(pending)
  hours  Decimal               @db.Decimal(5, 2)
  // Required (enforced in app code) when type = adjusted (the admin's
  // correction reason) or when an admin rejects a pending entry in their
  // admin capacity (not as the named counterpart) — same §4.4 audit
  // requirement, reused rather than adding a second reason column.
  reason String?

  // Set only for admin-initiated `adjusted` rows; null for self-reported
  // or auto-posted entries.
  createdByUserId String?
  createdByUser   User?   @relation("LedgerCreatedBy", fields: [createdByUserId], references: [id])

  // The counterpart or admin who confirmed/rejected a pending row. Null
  // for auto-posted rows (confirmed by construction) and while pending.
  resolvedByUserId String?
  resolvedByUser   User?     @relation("LedgerResolvedBy", fields: [resolvedByUserId], references: [id])
  resolvedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  meetingRequestAsRequesterSpend MeetingRequest? @relation("MeetingRequestRequesterLedger")
  meetingRequestAsRecipientEarn  MeetingRequest? @relation("MeetingRequestRecipientLedger")

  @@index([userId, status])
  @@map("contribution_ledger")
}

enum MeetingRequestStatus {
  pending
  accepted
  declined
  rescheduled
}

// Directory-originated meeting request (§4.7) — always two-party, no
// conversation/participant join tables needed. Accepting one posts two
// ledger rows (§4.4/§11's resolved open question #12): an auto-confirmed
// spend for the requester (system has full ground truth — both parties
// already interacted to reach acceptance), and a system-generated but
// still `pending` earn for the recipient, naming the requester as
// counterpart. The recipient's earn isn't auto-confirmed like the spend
// side — requiring the requester's peer confirmation is a deliberate
// anti-fraud check, so the recipient can't unilaterally credit
// themselves for a meeting.
model MeetingRequest {
  id            String               @id @default(cuid())
  senderId      String
  sender        User                 @relation("MeetingRequestSender", fields: [senderId], references: [id])
  recipientId   String
  recipient     User                 @relation("MeetingRequestRecipient", fields: [recipientId], references: [id])
  topic         String
  proposedTimes DateTime[]
  status        MeetingRequestStatus @default(pending)
  message       String?

  // Set on acceptance — the requester's auto-confirmed spend row. Null
  // until accepted (declined/rescheduled requests never get one).
  contributionLedgerId String?             @unique
  contributionLedger   ContributionLedger? @relation("MeetingRequestRequesterLedger", fields: [contributionLedgerId], references: [id])

  // Set on acceptance — the recipient's system-generated, pending-until-
  // the-requester-confirms earn row. Same lifecycle as any other
  // counterpart-confirmed entry (§4.4) once created; only its *creation*
  // is automatic here, not its confirmation.
  recipientContributionLedgerId String?             @unique
  recipientContributionLedger   ContributionLedger? @relation("MeetingRequestRecipientLedger", fields: [recipientContributionLedgerId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recipientId, status])
  @@index([senderId])
  @@map("meeting_requests")
}

// Directory-originated asynchronous message (§4.7). Threaded replies are
// a self-relation via parentId, email-style — not a live conversation.
model InboxMessage {
  id          String  @id @default(cuid())
  senderId    String
  sender      User    @relation("InboxMessageSender", fields: [senderId], references: [id])
  recipientId String
  recipient   User    @relation("InboxMessageRecipient", fields: [recipientId], references: [id])
  subject     String?
  body        String

  parentId String?
  parent   InboxMessage?  @relation("InboxMessageThread", fields: [parentId], references: [id])
  replies  InboxMessage[] @relation("InboxMessageThread")

  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([recipientId, readAt])
  @@index([senderId])
  @@index([parentId])
  @@map("inbox_messages")
}

// §4.10's notification types this objective's entities can produce
// directly; the remaining types (event/digest/board announcement) get
// added when those domains land in later phases. blog_comment/
// forum_reply_mention/resource_review_update were added once Blog,
// Knowledge Library, and Forums (§4.8/§4.9/§4.13) landed in Phase 5.
// digest/board_announcement added in Phase 6 (§4.10) — digest batching and
// announcement-sending jobs are separate later objectives; this only adds
// the enum values NotificationPreference/Announcement need to reference.
enum NotificationType {
  inbox_message
  meeting_request_received
  meeting_request_accepted
  meeting_request_declined
  meeting_request_rescheduled
  contribution_awarded
  blog_comment
  forum_reply_mention
  resource_review_update
  digest
  board_announcement
  survey_invitation
}

// Homegrown in-app notification feed (§4.10) — no third-party vendor.
// NotificationPreference/Announcement (opt-out prefs + board broadcasts)
// were out of scope for Phase 3.1's entity list and landed in Phase 6.
model Notification {
  id          String           @id @default(cuid())
  recipientId String
  recipient   User             @relation(fields: [recipientId], references: [id])
  type        NotificationType
  message     String
  link        String?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  @@index([recipientId, readAt])
  @@map("notifications")
}

// Phase 4 data model — Events & Calendar (PRD §4.6). Data foundation only;
// FullCalendar rendering, "Submit Event," and RSVP UI land in later
// objectives. Extensible enum per §4.6 (new types can be added later).
enum EventType {
  webinar
  workshop
  case_discussion
  student_event
  roundtable
  lecture
}

enum RecurrenceFrequency {
  daily
  weekly
  monthly
}

enum RSVPStatus {
  going
  cancelled
}

// Distinguishes a host's attendance (the §4.4/§4.6 auto-earn trigger) from
// a regular attendee's attendance record within the same table.
enum AttendanceRole {
  host
  attendee
}

// Event listing/calendar entry (§4.6). `open` gates public (§4.5 unauthenticated
// /events) vs. members-only visibility; `meetingUrl` is stored regardless but
// only ever served to RSVP'd members (enforced in API routes, not here) — the
// public listing never gets it. `deidentificationConfirmed` must be true
// before a case_discussion event can be published — also app-enforced (same
// pattern as MembershipApplication's phase-conditional required fields),
// since the rule depends on `type` and isn't expressible as a DB constraint.
model Event {
  id                        String    @id @default(cuid())
  title                     String
  description               String?
  type                      EventType
  hostId                    String
  host                      User      @relation("EventHost", fields: [hostId], references: [id])
  startsAt                  DateTime
  endsAt                    DateTime?
  open                      Boolean   @default(false)
  icon                      String?
  meetingUrl                String?
  deidentificationConfirmed Boolean   @default(false)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt

  recurrence    EventRecurrence?
  rsvps         RSVP[]
  attendances   Attendance[]
  registrations EventRegistration[]

  @@index([startsAt])
  @@map("events")
}

// Recurrence rule for a recurring Event (§4.6's "recurring events" feature).
// One row per recurring master; individual occurrences aren't materialized
// as separate Event rows — the calendar renderer (a later objective) expands
// them from this rule at render time.
model EventRecurrence {
  id        String              @id @default(cuid())
  eventId   String              @unique
  event     Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  frequency RecurrenceFrequency
  interval  Int                 @default(1)
  // Days of week the recurrence repeats on (0 = Sunday .. 6 = Saturday),
  // for weekly frequency only; ignored for daily/monthly.
  byWeekday Int[]               @default([])
  until     DateTime?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@map("event_recurrences")
}

model RSVP {
  id        String     @id @default(cuid())
  eventId   String
  event     Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId    String
  user      User       @relation("EventRsvp", fields: [userId], references: [id], onDelete: Cascade)
  status    RSVPStatus @default(going)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([eventId, userId])
  @@index([userId])
  @@map("rsvps")
}

// Captures a non-member's email (and optional name) when they register
// interest in an `open` event from the public /events page, without
// requiring a User account. Deliberately separate from RSVP: RSVP is
// member-only and feeds Attendance/Knowledge Hours, while this is just a
// lead-capture record for later membership-campaign outreach (no userId —
// same nullable-account-capture precedent as Donation/MembershipApplication).
model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  email     String
  name      String?
  createdAt DateTime @default(now())

  @@unique([eventId, email])
  @@index([email])
  @@map("event_registrations")
}

// Records that a user actually attended (vs. merely RSVP'd). A `host`-role
// row is the trigger for the §4.4 auto-posted Knowledge Hours earn
// transaction; `attendee`-role rows are just a record.
model Attendance {
  id          String         @id @default(cuid())
  eventId     String
  event       Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation("EventAttendance", fields: [userId], references: [id], onDelete: Cascade)
  role        AttendanceRole @default(attendee)
  checkedInAt DateTime       @default(now())
  createdAt   DateTime       @default(now())

  // Set only for a host-role row, once the auto-earn transaction has been
  // posted (§4.4/§4.6). The other direction of ContributionEvent.attendanceId.
  contributionEvent ContributionEvent?

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("attendance")
}

// Phase 5 data model — Blog, Knowledge Library & Forums (PRD §4.8/§4.9/§4.13).
// Data foundation only; editors, review-queue UI, and search indexing land
// in later 5.x objectives.

// ===== Blog (§4.8) =====

// Managed taxonomy for blog topic chips (§4.8 — "should be a managed
// taxonomy, not hardcoded"), same rationale as Skill.
model PostCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  posts Post[]

  @@map("post_categories")
}

model PostTag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  posts PostTagOnPost[]

  @@map("post_tags")
}

model PostTagOnPost {
  postId String
  post   Post    @relation(fields: [postId], references: [id], onDelete: Cascade)
  tagId  String
  tag    PostTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("post_tags_on_posts")
}

// Member-authored blog post (§4.8). `publishedAt` null = draft, set = live.
// `licenseConsented` gates publish per the Risk_and_Liability.md content-terms
// requirement (§4.15) — author retains IP, Nasiha gets a non-exclusive
// display right. `heroImageUrl` is a MinIO object key (attachments/ bucket),
// same "not a servable URL" convention as Profile.avatarUrl. `flagged`/
// `flagReason` (added Phase 6, §4.11) give Blog the same post-publish
// flaggability Library/Forums already had — a boolean + reason rather than
// KnowledgeItem's status enum, since a Post's publish state is already
// carried by `publishedAt` and doesn't need a combined enum.
model Post {
  id               String       @id @default(cuid())
  title            String
  slug             String       @unique
  body             String
  authorId         String
  author           User         @relation("PostAuthor", fields: [authorId], references: [id])
  categoryId       String
  category         PostCategory @relation(fields: [categoryId], references: [id])
  heroImageUrl     String?
  licenseConsented Boolean      @default(false)
  publishedAt      DateTime?
  flagged          Boolean      @default(false)
  flagReason       String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  tags     PostTagOnPost[]
  comments PostComment[]

  @@index([authorId])
  @@index([categoryId])
  @@index([publishedAt])
  @@map("posts")
}

// Threaded comment on a Post (§4.8), mirroring InboxMessage's parentId
// self-relation convention for replies.
model PostComment {
  id       String @id @default(cuid())
  postId   String
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId String
  author   User   @relation("PostCommentAuthor", fields: [authorId], references: [id])
  body     String

  parentId String?
  parent   PostComment?  @relation("PostCommentThread", fields: [parentId], references: [id])
  replies  PostComment[] @relation("PostCommentThread")

  createdAt DateTime @default(now())

  @@index([postId])
  @@index([parentId])
  @@map("post_comments")
}

// ===== Knowledge Library (§4.9) =====

// Library Steward review workflow (§4.9) — only `published` items are
// searchable/browsable; `pending_review` is visible to the submitter and to
// Stewards/admins; `flagged` items stay visible per the "community flagging,
// not formal peer review" model until a Steward removes them.
enum KnowledgeStatus {
  pending_review
  published
  flagged
  rejected
}

// Drives the "recorded lecture uses youtubeUrl instead of a
// KnowledgeAttachment" rule (§4.9) and the Library's content-type filter.
enum KnowledgeContentType {
  recorded_lecture
  article
  case_study
  guideline
}

// "Career-stage level" filter (§4.9) — the level *the content targets*, not
// the contributor's own career stage (see the existing CareerStage enum),
// and includes an "all levels" option that enum has no equivalent for.
enum KnowledgeLevel {
  student_friendly
  early_career
  advanced
  all_levels
}

model KnowledgeCategory {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())

  items KnowledgeItem[]

  @@map("knowledge_categories")
}

model KnowledgeTag {
  id   String @id @default(cuid())
  name String @unique
  slug String @unique

  items KnowledgeItemTag[]

  @@map("knowledge_tags")
}

model KnowledgeItemTag {
  knowledgeItemId String
  knowledgeItem   KnowledgeItem @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)
  tagId           String
  tag             KnowledgeTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([knowledgeItemId, tagId])
  @@index([tagId])
  @@map("knowledge_item_tags")
}

// Searchable/filterable resource repository entry (§4.9). `deidentificationConfirmed`
// is required (app-enforced, same pattern as MembershipApplication/Event)
// before a case_study item can leave pending_review. recorded_lecture items
// store `youtubeUrl` instead of a KnowledgeAttachment — Nasiha hosts the
// listing, not the media, mirroring Event.meetingUrl's Zoom/Meet pattern.
model KnowledgeItem {
  id                        String               @id @default(cuid())
  title                     String
  description               String
  contentType               KnowledgeContentType
  status                    KnowledgeStatus      @default(pending_review)
  level                     KnowledgeLevel
  contributorId             String
  contributor               User                 @relation("KnowledgeContributor", fields: [contributorId], references: [id])
  categoryId                String
  category                  KnowledgeCategory    @relation(fields: [categoryId], references: [id])
  youtubeUrl                String?
  deidentificationConfirmed Boolean              @default(false)
  licenseConsented          Boolean              @default(false)
  createdAt                 DateTime             @default(now())
  updatedAt                 DateTime             @updatedAt

  tags        KnowledgeItemTag[]
  attachments KnowledgeAttachment[]

  @@index([contributorId])
  @@index([categoryId])
  @@index([status])
  @@map("knowledge_items")
}

// Document/article/case-study binary only — never video (recorded lectures
// use KnowledgeItem.youtubeUrl instead, §4.9). `objectKey` is a MinIO key in
// the documents/ bucket, same "not a servable URL" convention as
// Profile.avatarUrl.
model KnowledgeAttachment {
  id              String        @id @default(cuid())
  knowledgeItemId String
  knowledgeItem   KnowledgeItem @relation(fields: [knowledgeItemId], references: [id], onDelete: Cascade)
  objectKey       String
  fileName        String
  mimeType        String
  sizeBytes       Int
  createdAt       DateTime      @default(now())

  @@index([knowledgeItemId])
  @@map("knowledge_attachments")
}

// ===== Discussion Forums (§4.13) =====

// Admin-manageable forum category (§4.13) — seeded with six categories from
// Member_Communications.md; `active`/`displayOrder` follow the same
// retire-without-delete + explicit-ordering convention as TeamMember (§4.12),
// since the org is expected to add/retire categories over time.
model Forum {
  id           String   @id @default(cuid())
  name         String   @unique
  slug         String   @unique
  description  String?
  displayOrder Int      @default(0)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  threads ForumThread[]
  follows ForumFollow[]

  @@map("forums")
}

// Follow toggle for a Forum (§4.13) — following suppresses per-post
// forum_reply_mention notifications in favor of future digest batching
// (§4.10, Phase 6); digest delivery itself isn't built yet, this only
// persists the toggle so createForumPost can check it.
model ForumFollow {
  id        String   @id @default(cuid())
  forumId   String
  forum     Forum    @relation(fields: [forumId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([forumId, userId])
  @@index([userId])
  @@map("forum_follows")
}

model ForumThread {
  id        String   @id @default(cuid())
  forumId   String
  forum     Forum    @relation(fields: [forumId], references: [id])
  authorId  String
  author    User     @relation("ForumThreadAuthor", fields: [authorId], references: [id])
  title     String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  posts ForumPost[]

  @@index([forumId])
  @@index([authorId])
  @@map("forum_threads")
}

// Top-level posts and replies are the same entity, threaded by
// `parentPostId` (§4.13) — same self-relation convention as PostComment/
// InboxMessage. `deidentificationConfirmed` mirrors KnowledgeItem/Event's
// app-enforced gate, only meaningful (and only enforced) for posts in the
// Clinical Discussions forum. `flagged` routes into the same shared
// moderation model as flagged Library content (§4.9/§4.13) — a boolean
// rather than a status enum since, unlike KnowledgeItem, a forum post has
// no publish workflow to also encode.
model ForumPost {
  id       String      @id @default(cuid())
  threadId String
  thread   ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  authorId String
  author   User        @relation("ForumPostAuthor", fields: [authorId], references: [id])
  body     String

  parentPostId String?
  parentPost   ForumPost?  @relation("ForumPostThread", fields: [parentPostId], references: [id])
  replies      ForumPost[] @relation("ForumPostThread")

  deidentificationConfirmed Boolean @default(false)
  flagged                   Boolean @default(false)
  // Set by a moderator/admin resolving a flagged post from /admin/content
  // (§4.11/§4.13). The row itself is kept (never deleted) so parentPostId
  // threading on any replies stays intact — the UI swaps in a placeholder
  // for a removed post's body instead.
  removed                   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([threadId])
  @@index([authorId])
  @@index([parentPostId])
  @@map("forum_posts")
}

// Phase 6 data model — Trust & Safety, Notification digests & Admin (PRD
// §4.10/§4.11/§4.15). Data foundation only; /admin/conduct,
// /admin/privacy-requests UI, the digest-batching job, and announcement
// send flow are later 6.x objectives.

// ===== Trust & Safety / Compliance (§4.15) =====

enum ConductActionTaken {
  warning
  suspension
  removal
}

// Code of Conduct enforcement record (§4.15). `reporterId` is nullable for
// system-flagged violations (no named reporter). A row starts as an open
// report (`actionTaken`/`handledByUserId`/`actionTakenAt` all null) created
// by a member's report (6.3); an admin reviewing it in /admin/conduct sets
// those three fields together once they record a warning/suspension/removal.
// Never publicly visible — visible only to the affected member (once
// actioned) and to admins (app-enforced, same as other visibility rules in
// this schema). `suspension`/`removal` actions are expected to also set
// User.suspended/suspendedAt, but that's an app-code side effect, not a DB
// constraint.
model CodeOfConductViolation {
  id              String              @id @default(cuid())
  reportedUserId  String
  reportedUser    User                @relation("ConductViolationReported", fields: [reportedUserId], references: [id])
  reporterId      String?
  reporter        User?               @relation("ConductViolationReporter", fields: [reporterId], references: [id])
  description     String
  actionTaken     ConductActionTaken?
  handledByUserId String?
  handledByUser   User?               @relation("ConductViolationHandledBy", fields: [handledByUserId], references: [id])
  actionTakenAt   DateTime?
  // Set when the reported member dismisses the notice from Settings/Dashboard
  // (self-service, not admin-controlled) — null means it's still an
  // outstanding "needs attention" item on the Dashboard.
  acknowledgedAt  DateTime?
  occurredAt      DateTime            @default(now())
  createdAt       DateTime            @default(now())

  @@index([reportedUserId])
  @@map("code_of_conduct_violations")
}

enum PrivacyRequestType {
  export
  deletion
}

// Same pending/confirmed-style lifecycle convention as LedgerStatus, applied
// to §4.15's export/deletion fulfillment workflow.
enum PrivacyRequestStatus {
  pending
  fulfilled
  rejected
}

// GDPR-style data export/deletion request (§4.15), fulfilled from
// /admin/privacy-requests. `handledByUserId` is null until an admin picks
// it up; `fulfilledAt` is set once the export/deletion has actually been
// carried out, not merely acknowledged.
model PrivacyDataRequest {
  id              String               @id @default(cuid())
  userId          String
  user            User                 @relation("PrivacyRequestUser", fields: [userId], references: [id])
  type            PrivacyRequestType
  status          PrivacyRequestStatus @default(pending)
  requestedAt     DateTime             @default(now())
  fulfilledAt     DateTime?
  handledByUserId String?
  handledByUser   User?                @relation("PrivacyRequestHandledBy", fields: [handledByUserId], references: [id])

  @@index([userId])
  @@map("privacy_data_requests")
}

// ===== Notifications (§4.10) =====

// Per-type opt-out (§4.10) — one row per (user, type) the member has
// explicitly opted out of; absence of a row means the default (opted in).
// `board_announcement` is deliberately excluded from being creatable for
// that type in app code — the Board's broadcast channel cannot be muted.
model NotificationPreference {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  optedOut  Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, type])
  @@map("notification_preferences")
}

// Board-authored broadcast (§4.10) — fans out to every member's
// notification feed (+ email) as a `board_announcement` Notification once
// sent. `sentAt` null = draft, set = sent, same nullable-timestamp-as-status
// convention as Post.publishedAt. Member-facing surfaces (feed, detail page,
// email) deliberately mask `author` behind a fixed "NASIHA Board" identity —
// `authorId` is still the real sender, used only by the admin history list.
// `retractedAt` set = hidden from the feed/detail page and its Notification
// rows deleted (can't un-send the email already delivered) — the row itself
// is kept, retracted, so the admin history list retains an audit trail.
model Announcement {
  id            String    @id @default(cuid())
  title         String
  body          String
  authorId      String
  author        User      @relation("AnnouncementAuthor", fields: [authorId], references: [id])
  // MinIO object key in the attachments/ bucket, same pattern as
  // Post.heroImageUrl — a single optional cover image, not a multi-file
  // attachment system.
  heroImageUrl  String?
  // Per-channel delivery toggles — which surfaces this send fanned out to.
  // Default true on all three preserves prior all-channels behavior for
  // existing rows and is the sensible default for new sends too.
  showInFeed    Boolean   @default(true)
  notifyInApp   Boolean   @default(true)
  sendEmail     Boolean   @default(true)
  sentAt        DateTime?
  retractedAt   DateTime?
  retractedById String?
  retractedBy   User?     @relation("AnnouncementRetractedBy", fields: [retractedById], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("announcements")
}

// ===== Surveys =====

enum SurveyStatus {
  draft
  scheduled
  open
  closed
}

enum SurveyQuestionType {
  short_text
  long_text
  single_choice
  multi_choice
  rating
  yes_no
}

// Admin-authored survey (community polling). Unlike Announcement, sending is
// a multi-step lifecycle (draft -> scheduled -> open -> closed) rather than
// immediate-on-create, since a survey needs a question set built up first
// and can be scheduled/reopened/closed independently of when it was
// authored. `generation` is bumped on every open/reopen so a stale delayed
// auto-close job (queued before a reopen) can no-op instead of closing a
// survey the admin just reopened — see lib/queues/survey-queue.ts.
model Survey {
  id          String       @id @default(cuid())
  title       String
  description String?
  authorId    String
  author      User         @relation("SurveyAuthor", fields: [authorId], references: [id])
  status      SurveyStatus @default(draft)
  // MinIO object key in the attachments/ bucket, same pattern as
  // Announcement.heroImageUrl/Post.heroImageUrl — a single optional cover
  // image, shown on the compose/edit form, the invite email, the public
  // respond page, and the What's New feed row.
  heroImageUrl String?

  // Audience checkboxes (default: members only) — resolved into
  // SurveyInvitation rows once, at send time, so the recipient list is a
  // snapshot rather than re-evaluated live as tiers/donations/registrations
  // change while the survey is open.
  audienceMembers          Boolean @default(true)
  audienceDonors           Boolean @default(false)
  audienceEventRegistrants Boolean @default(false)

  scheduledStartAt DateTime? // null + sent immediately => no scheduled-open job
  durationDays     Int? // null => no auto-close job
  openedAt         DateTime?
  closedAt         DateTime?
  closedById       String?
  closedBy         User?     @relation("SurveyClosedBy", fields: [closedById], references: [id])
  generation       Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  questions   SurveyQuestion[]
  invitations SurveyInvitation[]
  responses   SurveyResponse[]

  @@map("surveys")
}

model SurveyQuestion {
  id       String             @id @default(cuid())
  surveyId String
  survey   Survey             @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  order    Int
  prompt   String
  type     SurveyQuestionType
  required Boolean            @default(true)
  options  String[] // single_choice / multi_choice only

  answers SurveyAnswer[]

  @@index([surveyId])
  @@map("survey_questions")
}

// One row per resolved recipient at send time — the audience snapshot, the
// magic-link token that authenticates their response (no login required,
// even for members: a single unified response path for every source), and
// the dedup key. `source` records which audience checkbox produced this
// row, for the recipients report.
model SurveyInvitation {
  id          String    @id @default(cuid())
  surveyId    String
  survey      Survey    @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  email       String
  name        String?
  userId      String?
  user        User?     @relation(fields: [userId], references: [id])
  source      String // "member" | "donor" | "event_registrant"
  token       String    @unique
  sentAt      DateTime?
  respondedAt DateTime?

  response SurveyResponse?

  @@unique([surveyId, email])
  @@index([token])
  @@map("survey_invitations")
}

model SurveyResponse {
  id           String           @id @default(cuid())
  surveyId     String
  survey       Survey           @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  invitationId String           @unique
  invitation   SurveyInvitation @relation(fields: [invitationId], references: [id])
  submittedAt  DateTime         @default(now())

  answers SurveyAnswer[]

  @@index([surveyId])
  @@map("survey_responses")
}

model SurveyAnswer {
  id         String         @id @default(cuid())
  responseId String
  response   SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId String
  // Cascade (not the Restrict default) so deleting a Survey can cascade all
  // the way through Question -> Answer in one statement — Postgres
  // processes the Survey -> Question and Survey -> Response -> Answer
  // cascade paths in a single DELETE, and a Restrict here would race
  // against that (Question's delete blocked by an Answer that the other
  // path hasn't removed yet).
  question SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value    String[] // 1 element except multi_choice, which can have several

  @@unique([responseId, questionId])
  @@map("survey_answers")
}
